# ==============================================================================
# CloudPilot AI Environment Configurations Examples
# ==============================================================================

# Application Setup
APP_ENV=development
APP_NAME="CloudPilot AI"
DEBUG=true
PORT=8000
HOST=0.0.0.0

# Security (Access token: 15 mins, Refresh token: 7 days)
JWT_SECRET=super_secret_jwt_sign_key_change_me_in_production_32_chars_or_more
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption Key (32-bytes base64 encoded for AES-256-GCM credentials encryption KEK)
# Generate using: openssl rand -base64 32
ENCRYPTION_KEY=SGVsbG9Xb3JsZFNlY3JldEtleUZvckNyeXB0b2dyYXBoeTMyQnl0ZXM=

# Databases
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cloudpilot
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
CHAT_LIMIT_PER_MINUTE=20
AUTH_LIMIT_PER_MINUTE=5

# Structured Logging
LOG_LEVEL=info
LOG_FORMAT=json  # options: json, console
LOG_FILE_PATH=logs/cloudpilot.log
